{
  "name": "dnrun",
  "version": "1.0.0",
  "description": "Build a .NET project, copy its output to a temp dir, and run it from there — leaving bin/ unlocked so coding agents/tools can rebuild.",
  "type": "module",
  "bin": {
    "dotnetrun": "bin/dotnetrun.js"
  },
  "engines": {
    "node": ">=22.4.0"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "dotnet",
    "build",
    "run",
    "robocopy",
    "cli",
    "hot-reload",
    "agent",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rockyway/dotnet-run.git"
  },
  "homepage": "https://github.com/rockyway/dotnet-run#readme",
  "bugs": {
    "url": "https://github.com/rockyway/dotnet-run/issues"
  },
  "author": "Tam Tran <tamtranthien@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
